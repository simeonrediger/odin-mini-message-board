<%- include('../partials/layout-start', { isMessageBoardPage: true }) %>

<div data-scroll-to-bottom class="message-board">
  <% messages.forEach(message => { %>
    <%- include('../partials/message', { message }) %>
  <% }); %>
</div>
<a href="/new-message" class="button inline-block margin-top">Post a message</a>

<%- include('../partials/layout-end') %>
