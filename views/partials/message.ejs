<article class="message">
  <% if (locals.id) { %>
    <a href="/message/<%= locals.id %>" class="message-details-link">
  <% } %>
    <div class="message-header">
      <p class="message-author"><%= author || 'Anonymous' %></p>
      <p class="message-date"><%= date.toLocaleString() %></p>
    </div>
    <p class="message-text"><%= text || 'No message content' %></p>
  <% if (locals.id) { %>
    </a>
  <% } %>
</article>
